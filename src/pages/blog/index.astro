---
import Layout from '../../layouts/Layout.astro';

// Futuro: Aquí obtendrás tus posts desde un CMS o archivos locales
const posts = [
  {
    slug: 'primer-post',
    title: 'Mi primer post en el blog',
    description: 'Este es un resumen de mi primer post. Hablo sobre mi viaje en el desarrollo web.',
    date: '18 de junio de 2025',
  },
  {
    slug: 'segundo-post',
    title: 'Por qué elegí Astro',
    description: 'Astro es un framework increíble para sitios de contenido. Aquí explico por qué lo estoy usando para mi portfolio y blog.',
    date: '15 de junio de 2025',
  },
  // Añade más posts aquí
];
---

<Layout title="Blog">
  <section id="blog" class="py-12">
    <h1 class="text-5xl font-bold mb-12">Mi Blog</h1>
    <div class="space-y-12">
      {posts.map(post => (
        <article>
          <h2 class="text-3xl font-bold mb-2">
            <a href={`/blog/${post.slug}`} class="hover:text-secondary transition-colors duration-200">
              {post.title}
            </a>
          </h2>
          <p class="text-gray-400 mb-4">{post.date}</p>
          <p class="mb-4">{post.description}</p>
          <a href={`/blog/${post.slug}`} class="text-secondary font-bold hover:underline">
            Leer más &rarr;
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
