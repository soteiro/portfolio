---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div id="home"></div>
  <main class="p-6 lg:ml-52 md:ml-52 sm:ml-0 sm:p-14 md:p-16 lg:p-16">
    <!-- inicio -->
    <section id="inicio" class="flex flex-col justify-center mt-20 sm:mt-15 md:mt-0 lg:mt-10">
      <div class="mb-8">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold">Hola,</h1>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold">Soy Diego,</h1>
        <p class="text-3xl sm:text-4xl md:text-6xl mt-4 text-gray-400">
          Web Developer
        </p>
        <p class="mt-6 max-w-xl text-base md:text-lg text-gray-300">
          Desarrollador Front-End autodidacta, fascinado por crear aplicaciones e interfaces
          modernas y atractivas.
        </p>
      </div>
      
      <!-- anchor contact -->
      <a
        class="contact-button w-40 h-10 flex justify-center items-center border-2 border-secondary ml-0 md:ml-5 text-lg md:text-xl text-secondary rounded-lg font-semibold"
        href="#contacto">Contáctame</a
      >
    </section>

    <!-- sobre mi -->
    <section id="sobre-mi" class="py-10 md:py-20">
      <h2 class="text-3xl md:text-4xl font-bold mb-8">Sobre mí</h2>
      <p class="text-gray-400 max-w-3xl">
        Soy Diego Ignacio Soto, desarrollador web con experiencia en la creación de sitios web y
        aplicaciones. Me tengo experiencia en tecnologías modernas como Astro, React y
        Tailwind CSS. Siempre estoy aprendiendo de forma autodidacta y buscando
        nuevos desafíos para mejorar mis habilidades.
      </p>
    </section>

    <section
      id="skills"
      class="py-16 md:py-20 bg-zinc-900 -mx-6 md:-mx-12 lg:-mx-16 px-6 md:px-12 lg:px-16"
    >
      <h2 class="text-3xl md:text-4xl font-bold mb-8">Mi Stack</h2>
      <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        <li class="bg-zinc-800 p-4 rounded-lg text-center font-semibold">JavaScript</li>
        <li class="bg-zinc-800 p-4 rounded-lg text-center font-semibold">TypeScript</li>
        <li class="bg-zinc-800 p-4 rounded-lg text-center font-semibold">Astro</li>
        <li class="bg-zinc-800 p-4 rounded-lg text-center font-semibold">React</li>
        <li class="bg-zinc-800 p-4 rounded-lg text-center font-semibold">Tailwind CSS</li>
        <li class="bg-zinc-800 p-4 rounded-lg text-center font-semibold">Node.js</li>
        <li class="bg-zinc-800 p-4 rounded-lg text-center font-semibold">Git & GitHub</li>
      </ul>
    </section>

    <!-- sección proyectos -->
    <section id="proyectos" class="py-16 md:py-20">
      <h2 class="text-3xl md:text-4xl font-bold mb-8">Proyectos</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-zinc-800 rounded-lg p-6">
          <h3 class="text-xl md:text-2xl font-bold mb-2">Proyecto 1</h3>
          <p class="text-gray-400">
            Una breve descripción de tu proyecto. Qué tecnologías usaste y cuál
            fue tu rol.
          </p>
        </div>
        <div class="bg-zinc-800 rounded-lg p-6">
          <h3 class="text-xl md:text-2xl font-bold mb-2">Proyecto 2</h3>
          <p class="text-gray-400">
            Una breve descripción de tu proyecto. Qué tecnologías usaste y cuál
            fue tu rol.
          </p>
        </div>
      </div>
    </section>

    <!-- sección Blog -->
    <section
      id="blog"
      class="py-16 md:py-20 bg-zinc-900 -mx-6 md:-mx-12 lg:-mx-16 px-6 md:px-12 lg:px-16"
    >
      <h2 class="text-3xl md:text-4xl font-bold mb-8">Blog</h2>
      <p class="text-gray-400">
        Aquí puedes mostrar las últimas entradas de tu blog. Próximamente...
      </p>
    </section>	<!--sección contacto  -->
	<section id="contacto" class="py-12 md:py-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Contacto</h2>
      <div class="max-w-xl">
        <p class="text-gray-400 mb-8">
			¿Tienes alguna pregunta, comentario o simplemente quieres saludarme? ¡Completa el formulario y te responderé lo antes posible!
        </p>
        
        <form id="contactForm" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium mb-1">Nombre <span class="text-secondary">*</span></label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                class="w-full px-3 py-2 bg-zinc-800 border border-zinc-700 rounded-md focus:ring-2 focus:ring-secondary focus:border-transparent transition-colors text-white placeholder-gray-400"
                placeholder="Tu nombre"
              >
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium mb-1">Email <span class="text-secondary">*</span></label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                class="w-full px-3 py-2 bg-zinc-800 border border-zinc-700 rounded-md focus:ring-2 focus:ring-secondary focus:border-transparent transition-colors text-white placeholder-gray-400"
                placeholder="tu@email.com"
              >
            </div>
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium mb-1">Asunto <span class="text-secondary">*</span></label>
            <input 
              type="text" 
              id="subject" 
              name="subject" 
              required 
              class="w-full px-3 py-2 bg-zinc-800 border border-zinc-700 rounded-md focus:ring-2 focus:ring-secondary focus:border-transparent transition-colors text-white placeholder-gray-400"
              placeholder="¿En qué puedo ayudarte?"
            >
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium mb-1">Mensaje <span class="text-secondary">*</span></label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              required 
              class="w-full px-3 py-2 bg-zinc-800 border border-zinc-700 rounded-md focus:ring-2 focus:ring-secondary focus:border-transparent transition-colors text-white placeholder-gray-400 resize-none"
              placeholder="Cuéntame..."
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            id="submitBtn"
            class="w-full bg-secondary text-zinc-900 py-2.5 px-6 rounded-md font-semibold hover:bg-opacity-90 transition-all duration-300"
          >
            Enviar
          </button>
        </form>
        
        <!-- Mensaje de respuesta -->
        <div id="responseMessage" class="mt-4 p-3 rounded-md text-center hidden text-sm">
        </div>
         
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* botón contacto  */
  .contact-button {
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .contact-button::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--color-secondary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease-in-out;
    z-index: -1;
  }

  .contact-button:hover {
    color: #18181b; /* zinc-900 */
  }
  .contact-button:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>

<script>
  declare global {
    interface Window {
      emailjs: {
        init: (publicKey: string) => void;
        send: (serviceId: string, templateId: string, params: Record<string, any>) => Promise<any>;
      };
    }
  }


  interface FormData {
    name: string | null;
    email: string | null;
    subject: string | null;
    message: string | null;
  }

  interface ValidatedFormData {
    name: string;
    email: string;
    subject: string;
    message: string;
  }
  
  document.addEventListener('astro:page-load', () => {
   
    if (typeof window !== 'undefined' && window.emailjs) {
      window.emailjs.init('y02IIaIj0rzf-2cNz'); 
    }
    
    const contactForm = document.getElementById('contactForm') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;
    const responseMessage = document.getElementById('responseMessage') as HTMLElement | null;
    
    if (contactForm && submitBtn && responseMessage) {
      contactForm.addEventListener('submit', async function(e: Event) {
        e.preventDefault();
        
        // Obtener datos 
        const formData = new FormData(this as HTMLFormElement);
        const data: FormData = {
          name: formData.get('name') as string | null,
          email: formData.get('email') as string | null,
          subject: formData.get('subject') as string | null,
          message: formData.get('message') as string | null
        };
        
        // Validar campos
        const validatedData = validateForm(data);
        if (!validatedData) {
          showMessage('Por favor, completa todos los campos correctamente.', 'error');
          return;
        }
        
        // Cambiar estado del botón
        submitBtn.textContent = 'Enviando...';
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
        
        try {
          // Verificar que EmailJS esté bien
          if (!window.emailjs) {
            throw new Error('EmailJS no está disponible');
          }

          console.log('Enviando con datos:', validatedData); // Debug

         
          await window.emailjs.send(
            'service_11by89c',    // Tu Service ID real
            'template_ifxxuvg',   // Tu Template ID real
            {
              from_name: validatedData.name,
              from_email: validatedData.email,
              subject: validatedData.subject,
              message: validatedData.message,
              reply_to: validatedData.email
            }
          );
          
          showMessage('¡Mensaje enviado correctamente! Te responderé pronto.', 'success');
          contactForm.reset();
          
        } catch (error: unknown) {
          console.error('Error al enviar:', error);
          const errorMessage = error instanceof Error ? error.message : 'Error desconocido';
          showMessage(`Error: ${errorMessage}`, 'error');
        } finally {
          // Restaurar estado del botón
          submitBtn.textContent = 'Enviar';
          submitBtn.disabled = false;
          submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      });
    }
    
    function validateForm(data: FormData): ValidatedFormData | null {
      const emailRegex: RegExp = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      
      // Verificar campos no estén vacíos
      if (!data.name || data.name.trim() === '' ||
          !data.email || !emailRegex.test(data.email) ||
          !data.subject || data.subject.trim() === '' ||
          !data.message || data.message.trim() === '') {
        return null;
      }

      return {
        name: data.name.trim(),
        email: data.email.trim(),
        subject: data.subject.trim(),
        message: data.message.trim()
      };
    }
      function showMessage(message: string, type: 'success' | 'error'): void {
      if (!responseMessage) return;
      
      responseMessage.textContent = message;
      responseMessage.className = `mt-4 p-3 rounded-md text-center text-sm ${
        type === 'success' 
          ? 'bg-green-900 text-green-300 border border-green-700' 
          : 'bg-red-900 text-red-300 border border-red-700'
      }`;
      responseMessage.classList.remove('hidden');
      
      // Ocultar mesaje
      setTimeout(() => {
        if (responseMessage) {
          responseMessage.classList.add('hidden');
        }
      }, 5000);
    }
  });
</script>
