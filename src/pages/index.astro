---
import Layout from "@layouts/Layout.astro";
import About from "@components/sections/About.astro";
import Contact from "@components/sections/Contact.astro";
import Blog from "@components/sections/Blog.astro";
import Projects from "@components/sections/Proyects.astro";
import Skills from "@components/sections/Skills.astro";
import Inicio from "@components/sections/Inicio.astro";
---

<Layout>
  <main class="p-6 lg:ml-52 md:ml-52 sm:ml-0 sm:p-14 md:p-16 lg:p-16">
    <div id="home"></div>
    <Inicio />
    <About />
    <Skills />
    <Projects />
    <Blog />
    <Contact />
  </main>
</Layout>

<style>
  /* botón contacto  */
  .contact-button {
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .contact-button::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--color-secondary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease-in-out;
    z-index: -1;
  }

  .contact-button:hover {
    color: #18181b; /* zinc-900 */
  }
  .contact-button:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>

<script>
  declare global {
    interface Window {
      emailjs: {
        init: (publicKey: string) => void;
        send: (serviceId: string, templateId: string, params: Record<string, any>) => Promise<any>;
      };
    }
  }


  interface FormData {
    name: string | null;
    email: string | null;
    subject: string | null;
    message: string | null;
  }

  interface ValidatedFormData {
    name: string;
    email: string;
    subject: string;
    message: string;
  }
  
  document.addEventListener('astro:page-load', () => {
   
    if (typeof window !== 'undefined' && window.emailjs) {
      window.emailjs.init('y02IIaIj0rzf-2cNz'); 
    }
    
    const contactForm = document.getElementById('contactForm') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;
    const responseMessage = document.getElementById('responseMessage') as HTMLElement | null;
    
    if (contactForm && submitBtn && responseMessage) {
      contactForm.addEventListener('submit', async function(e: Event) {
        e.preventDefault();
        
        // Obtener datos 
        const formData = new FormData(this as HTMLFormElement);
        const data: FormData = {
          name: formData.get('name') as string | null,
          email: formData.get('email') as string | null,
          subject: formData.get('subject') as string | null,
          message: formData.get('message') as string | null
        };
        
        // Validar campos
        const validatedData = validateForm(data);
        if (!validatedData) {
          showMessage('Por favor, completa todos los campos correctamente.', 'error');
          return;
        }
        
        // Cambiar estado del botón
        submitBtn.textContent = 'Enviando...';
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
        
        try {
          // Verificar que EmailJS esté bien
          if (!window.emailjs) {
            throw new Error('EmailJS no está disponible');
          }

          console.log('Enviando con datos:', validatedData); // Debug

         
          await window.emailjs.send(
            'service_11by89c',    // Tu Service ID real
            'template_ifxxuvg',   // Tu Template ID real
            {
              from_name: validatedData.name,
              from_email: validatedData.email,
              subject: validatedData.subject,
              message: validatedData.message,
              reply_to: validatedData.email
            }
          );
          
          showMessage('¡Mensaje enviado correctamente! Te responderé pronto.', 'success');
          contactForm.reset();
          
        } catch (error: unknown) {
          console.error('Error al enviar:', error);
          const errorMessage = error instanceof Error ? error.message : 'Error desconocido';
          showMessage(`Error: ${errorMessage}`, 'error');
        } finally {
          // Restaurar estado del botón
          submitBtn.textContent = 'Enviar';
          submitBtn.disabled = false;
          submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      });
    }
    
    function validateForm(data: FormData): ValidatedFormData | null {
      const emailRegex: RegExp = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      
      // Verificar campos no estén vacíos
      if (!data.name || data.name.trim() === '' ||
          !data.email || !emailRegex.test(data.email) ||
          !data.subject || data.subject.trim() === '' ||
          !data.message || data.message.trim() === '') {
        return null;
      }

      return {
        name: data.name.trim(),
        email: data.email.trim(),
        subject: data.subject.trim(),
        message: data.message.trim()
      };
    }
      function showMessage(message: string, type: 'success' | 'error'): void {
      if (!responseMessage) return;
      
      responseMessage.textContent = message;
      responseMessage.className = `mt-4 p-3 rounded-md text-center text-sm ${
        type === 'success' 
          ? 'bg-green-900 text-green-300 border border-green-700' 
          : 'bg-red-900 text-red-300 border border-red-700'
      }`;
      responseMessage.classList.remove('hidden');
      
      // Ocultar mesaje
      setTimeout(() => {
        if (responseMessage) {
          responseMessage.classList.add('hidden');
        }
      }, 5000);
    }
  });
</script>
