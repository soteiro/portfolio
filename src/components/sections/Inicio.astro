<!-- inicio -->
<section id="inicio" class="flex flex-col justify-center mt-12 sm:mt-8 md:mt-0 lg:mt-6 ">
  <div class="mb-6">
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold">Hola,</h1>
    <h1 class="title-line-2 text-4xl sm:text-5xl md:text-6xl font-bold opacity-0 transform translate-y-10">Soy Diego,</h1>
    <p class="subtitle text-3xl sm:text-4xl md:text-6xl mt-3 text-gray-400 opacity-0 transform translate-y-10">
      Web Developer
    </p>
    <p class="description my-4 max-w-xl text-base md:text-lg text-gray-300 opacity-0 transform translate-y-10">
      Desarrollador Front-End autodidacta, fascinado por crear aplicaciones e interfaces
      modernas y atractivas.
    </p>
  </div>
  
  <!-- anchor contact -->
  <a
    class="contact-button description w-40 h-10 flex justify-center items-center border-2 border-secondary ml-0 md:ml-5 text-lg md:text-xl text-secondary z-30 rounded-lg font-semibold  transform translate-y-10 opacity-0"
    href="#contacto">Contáctame</a
  >
</section>
<style>
  /* botón contacto  */
  .contact-button {
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .contact-button::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--color-secondary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease-in-out;
    z-index: -1;
  }

  .contact-button:hover {
    color: #18181b; /* zinc-900 */
  }
  .contact-button:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>
<script>
  import { gsap } from "gsap";

  // Timeline para coordinar las animaciones
  const tl = gsap.timeline({ delay: 0.8 });

  // Animar cada elemento en secuencia
  tl.to(".title-line-2", {
    opacity: 1,
    y: 0,
    duration: 0.9,
    ease: "power3.out"
  }, "-=0.4") 
  .to(".subtitle", {
    opacity: 1,
    y: 0,
    duration: 0.9,
    ease: "power3.out"
  }, "-=0.4")
  .to(".description", {
    opacity: 1,
    y: 0,
    duration: 0.9,
    ease: "power3.out"
  }, "-=0.3");
 
 

</script>